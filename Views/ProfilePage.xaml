<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.ProfilePage"
             BackgroundColor="White"
             Title="Profile">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Image
            Source="ictu.png"
            HeightRequest="120"
            WidthRequest="120"
            HorizontalOptions="Center"/>

        <Border
            StrokeThickness="0"
            StrokeShape="RoundRectangle 15"
            BackgroundColor="#F4F8F9"
            Padding="20">

            <VerticalStackLayout Spacing="10">

                <Label Text="Name: User Name"
                       FontSize="18"
                       TextColor="#00697F"/>

                <Label Text="Email: user@email.com"
                       FontSize="18"
                       TextColor="#00697F"/>

                <Label Text="Student ID: 123456"
                       FontSize="18"
                       TextColor="#00697F"/>

            </VerticalStackLayout>

        </Border>

        <Button
            Text="Logout"
            BackgroundColor="#00697F"
            TextColor="White"
            HeightRequest="50"
            CornerRadius="10"/>

    </VerticalStackLayout>

</ContentPage>