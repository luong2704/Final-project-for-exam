<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.DashboardStatCard"
             x:Name="cardRoot">

    <Frame CornerRadius="12"
           BorderColor="#E0E0E0"
           Padding="15"
           HasShadow="True"
           Background="White">

        <VerticalStackLayout Spacing="8" VerticalOptions="Center">

            <!-- Card Title (e.g. "Total Events") -->
            <Label Text="{Binding Title, Source={x:Reference cardRoot}}"
                   FontSize="14"
                   TextColor="#999999" />

            <!-- Card Value (e.g. 42) — colored per AccentColor -->
            <Label Text="{Binding Value, Source={x:Reference cardRoot}}"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="{Binding AccentColor, Source={x:Reference cardRoot}}" />

        </VerticalStackLayout>
    </Frame>

</ContentView>
