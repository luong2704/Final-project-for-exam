<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Campus.ViewModels"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             xmlns:converters="clr-namespace:Campus.Converters"
             Title="Event Details"
             BackgroundColor="#F7FAFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero Image -->
            <Border StrokeThickness="0"
                    HeightRequest="220"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    BackgroundColor="#E2E8F0">
                <Image Source="{Binding Image}"
                       Aspect="AspectFill" />
            </Border>

            <!-- Details Region -->
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" TextColor="#1A202C" />

                <!-- Badges -->
                <HorizontalStackLayout Spacing="8">
                    <Border StrokeThickness="0" BackgroundColor="{Binding StatusColor}" StrokeShape="RoundRectangle 8" Padding="8,4">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding StatusIcon}" TextColor="White" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding EventStatus}" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    <Border StrokeThickness="0" BackgroundColor="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="8,4">
                        <Label Text="{Binding Category}" TextColor="#374151" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Date & Location Simple -->
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="14" TextColor="#718096" />
                    <Label Text="•" FontSize="14" TextColor="#718096" />
                    <Label Text="{Binding Location}" FontSize="14" TextColor="#718096" />
                </HorizontalStackLayout>

                <!-- Separator -->
                <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,5" />

                <!-- Description -->
                <Label Text="About this event" FontSize="16" TextColor="#2D3748" FontAttributes="Bold" />
                <Label Text="{Binding Description}" FontSize="15" TextColor="#4A5568" LineBreakMode="WordWrap" />

                <!-- Registered Status -->
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F0FFF4" Padding="14,10" IsVisible="{Binding IsRegistered}" Margin="0,15,0,0">
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="16" VerticalOptions="Center" />
                        <Label Text="You are registered for this event" FontSize="14" TextColor="#276749" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Action Button -->
                <Button Text="Register for this Event"
                        Command="{Binding RegisterCommand}"
                        IsVisible="{Binding IsRegistered, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="#00697F"
                        TextColor="White"
                        HeightRequest="52"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,10,0,0" />

                <Button Text="← Back to Events"
                        BackgroundColor="#EDF2F7"
                        TextColor="#4A5568"
                        HeightRequest="50"
                        CornerRadius="12"
                        FontSize="14"
                        Command="{Binding GoBackCommand}" />
                        
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
