<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Campus.ViewModels"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             Title="Event Details"
             BackgroundColor="#F7FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ Event Image Hero ═══ -->
            <Border StrokeThickness="0"
                    HeightRequest="220"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    BackgroundColor="#E2E8F0">
                <Image Source="{Binding Image}"
                       Aspect="AspectFill" />
            </Border>

            <!-- Title & Date -->
            <VerticalStackLayout x:Name="TitleRegion" Spacing="5">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />
                
                <HorizontalStackLayout Spacing="8">
                    <!-- Status Badge -->
                    <Border StrokeThickness="0" 
                            BackgroundColor="{Binding StatusColor}" 
                            StrokeShape="RoundRectangle 8" 
                            Padding="8,4">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding StatusIcon}" TextColor="White" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding EventStatus}" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    
                    <!-- Category Badge -->
                    <Border StrokeThickness="0" 
                            BackgroundColor="#E5E7EB" 
                            StrokeShape="RoundRectangle 8" 
                            Padding="8,4">
                        <Label Text="{Binding Category}" TextColor="#374151" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="14" TextColor="Gray" />
                    <Label Text="•" FontSize="14" TextColor="Gray" />
                    <Label Text="{Binding Location}" FontSize="14" TextColor="Gray" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">

            <VerticalStackLayout x:Name="ActionRegion" Margin="0,20,0,0" Spacing="12">
                <Button Text="Register for this Event →"
                        Command="{Binding RegisterCommand}"
                        IsVisible="{Binding IsRegistered, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="#00697F"
                        TextColor="White"
                        HeightRequest="52"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="15" />

                <Border IsVisible="{Binding IsRegistered}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#DCFCE7"
                        Padding="14,10">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                Padding="10,5">
                            <!-- Upcoming = green, Past = gray -->
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsUpcoming}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="#C6F6D5" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsPast}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="#E2E8F0" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding EventStatus}"
                                   FontSize="12"
                                   FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsUpcoming}"
                                                 Value="True">
                                        <Setter Property="TextColor" Value="#276749" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsPast}"
                                                 Value="True">
                                        <Setter Property="TextColor" Value="#718096" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Title -->
                    <Label Text="{Binding Title}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A202C"
                           LineBreakMode="WordWrap" />

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             Color="#E2E8F0"
                             Margin="0,4" />

                    <!-- Date -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📅"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <VerticalStackLayout>
                            <Label Text="Date &amp; Time"
                                   FontSize="11"
                                   TextColor="#A0AEC0" />
                            <Label Text="{Binding Date, StringFormat='{0:dddd, MMMM dd, yyyy · HH:mm}'}"
                                   FontSize="14"
                                   TextColor="#2D3748"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Location -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <VerticalStackLayout>
                            <Label Text="Location"
                                   FontSize="11"
                                   TextColor="#A0AEC0" />
                            <Label Text="{Binding Location}"
                                   FontSize="14"
                                   TextColor="#2D3748"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             Color="#E2E8F0"
                             Margin="0,4" />

                    <!-- Description -->
                    <Label Text="About this event"
                           FontSize="14"
                           TextColor="#718096"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Description}"
                           FontSize="14"
                           TextColor="#4A5568"
                           LineBreakMode="WordWrap" />

                    <!-- Registration status -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#F0FFF4"
                            Padding="14,10"
                            IsVisible="{Binding IsRegistered}"
                            Margin="0,8,0,0">
                        <HorizontalStackLayout Spacing="8"
                                                HorizontalOptions="Center">
                            <Label Text="✅"
                                   FontSize="16"
                                   VerticalOptions="Center" />
                            <Label Text="You are registered for this event"
                                   FontSize="13"
                                   TextColor="#276749"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ Action Buttons ═══ -->
            <VerticalStackLayout Padding="16,0,16,24"
                                 Spacing="10">

                <!-- Register button (only if upcoming & not registered) -->
                <Button Text="Register for Event"
                        BackgroundColor="#00697F"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="16"
                        Command="{Binding RegisterCommand}"
                        IsVisible="{Binding IsUpcoming}" />

                <!-- Go back button -->
                <Button Text="← Back to Events"
                        BackgroundColor="#EDF2F7"
                        TextColor="#4A5568"
                        HeightRequest="50"
                        CornerRadius="12"
                        FontSize="14"
                        Command="{Binding GoBackCommand}" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
