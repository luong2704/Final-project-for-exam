<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Campus.ViewModels"
             xmlns:conv="clr-namespace:Campus.Converters"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             xmlns:converters="clr-namespace:Campus.Converters"
             Title="Event Details"
             BackgroundColor="#F7FAFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero Image -->
            <Border StrokeThickness="0"
                    HeightRequest="220"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    BackgroundColor="#E2E8F0">
                <Image Source="{Binding Image}"
                       Aspect="AspectFill" />
            </Border>

            <!-- Details Region -->
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" TextColor="#1A202C" />
                <HorizontalStackLayout Spacing="8">
                    <Border StrokeThickness="0" BackgroundColor="{Binding StatusColor}" StrokeShape="RoundRectangle 8" Padding="8,4">
            <VerticalStackLayout x:Name="TitleRegion" Spacing="5" Padding="16,12,16,0">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />

                <HorizontalStackLayout Spacing="8">
                    <!-- Status Badge -->
                    <Border StrokeThickness="0"
                            BackgroundColor="{Binding StatusColor}"
                            StrokeShape="RoundRectangle 8"
                            Padding="8,4">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding StatusIcon}" TextColor="White" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding EventStatus}" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    <Border StrokeThickness="0" BackgroundColor="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="8,4">
                    <Border StrokeThickness="0"
                            BackgroundColor="#E5E7EB"
                            StrokeShape="RoundRectangle 8"
                            Padding="8,4">
                        <Label Text="{Binding Category}" TextColor="#374151" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Date & Location Simple -->
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="14" TextColor="#718096" />
                    <Label Text="•" FontSize="14" TextColor="#718096" />
                    <Label Text="{Binding Location}" FontSize="14" TextColor="#718096" />
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,5" />
                <Label Text="About this event" FontSize="16" TextColor="#2D3748" FontAttributes="Bold" />
                <Label Text="{Binding Description}" FontSize="15" TextColor="#4A5568" LineBreakMode="WordWrap" />
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F0FFF4" Padding="14,10" IsVisible="{Binding IsRegistered}" Margin="0,15,0,0">
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="16" VerticalOptions="Center" />
                        <Label Text="You are registered for this event" FontSize="14" TextColor="#276749" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
                <Button Text="Register for this Event"
            <!-- Description -->
            <VerticalStackLayout x:Name="DescriptionRegion" Spacing="10" Padding="16,10,16,0">
                <Label Text="About this event" FontSize="18" FontAttributes="Bold" />
                <Label Text="{Binding Description}" FontSize="16" LineHeight="1.4"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
            </VerticalStackLayout>
            <VerticalStackLayout x:Name="ActionRegion" Padding="16,20,16,24" Spacing="12">

                <!-- Register Button: chỉ hiện khi CHƯA đăng ký -->
                <Button Text="Register for this Event →"
                        Command="{Binding RegisterCommand}"
                        IsVisible="{Binding IsRegistered, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="#00697F"
                        TextColor="White"
                        HeightRequest="52"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,10,0,0" />

                <Button Text="← Back to Events"
                        BackgroundColor="#EDF2F7"
                        TextColor="#4A5568"
                        HeightRequest="50"
                        CornerRadius="12"
                        FontSize="14"
                        Command="{Binding GoBackCommand}" />
                        FontSize="15" />

                <!-- Already Registered Status Badge (Team 4) -->
                <Border IsVisible="{Binding IsRegistered}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#DCFCE7"
                        Padding="14,10">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#16A34A"
                                Padding="6,4"
                                VerticalOptions="Center">
                            <Label Text="✓"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Text="You are already registered"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="#166534" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
