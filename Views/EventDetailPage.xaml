<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Campus.ViewModels"
             xmlns:conv="clr-namespace:Campus.Converters"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="viewmodels:EventDetailViewModel"
             Title="Event Details">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Image Banner -->
            <Border x:Name="ImageRegion"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#F0F0F0"
                    HeightRequest="200"
                    StrokeThickness="0">
                <Image Source="{Binding Image}" Aspect="AspectFill"
                       HorizontalOptions="Fill" VerticalOptions="Fill" />
            </Border>

            <!-- Title & Date -->
            <VerticalStackLayout x:Name="TitleRegion" Spacing="5">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />
                
                <HorizontalStackLayout Spacing="8">
                    <!-- Status Badge -->
                    <Border StrokeThickness="0" 
                            BackgroundColor="{Binding StatusColor}" 
                            StrokeShape="RoundRectangle 8" 
                            Padding="8,4">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding StatusIcon}" TextColor="White" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding EventStatus}" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    
                    <!-- Category Badge -->
                    <Border StrokeThickness="0" 
                            BackgroundColor="#E5E7EB" 
                            StrokeShape="RoundRectangle 8" 
                            Padding="8,4">
                        <Label Text="{Binding Category}" TextColor="#374151" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="14" TextColor="Gray" />
                    <Label Text="•" FontSize="14" TextColor="Gray" />
                    <Label Text="{Binding Location}" FontSize="14" TextColor="Gray" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout x:Name="DescriptionRegion" Spacing="10" Margin="0,10,0,0">
                <Label Text="About this event" FontSize="18" FontAttributes="Bold" />
                <Label Text="{Binding Description}" FontSize="16" LineHeight="1.4"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="ActionRegion" Margin="0,20,0,0" Spacing="12">
                <Button Text="Register for this Event →"
                        BackgroundColor="#00697F"
                        TextColor="White"
                        HeightRequest="52"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="15" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
