<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Campus.ViewModels"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="viewmodels:EventDetailViewModel"
             Title="Event Details">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            
           
            <Border x:Name="ImageRegion" StrokeShape="RoundRectangle 12" BackgroundColor="#F0F0F0" HeightRequest="200" StrokeThickness="0" IsClippedToBounds="True">
               <Image Source="{Binding Image}" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill" />
            </Border>

            
            <VerticalStackLayout x:Name="TitleRegion" Spacing="5">
                <Label Text="[Event Title placeholder]" FontSize="24" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="10">
                    <Label Text="[Date placeholder]" FontSize="14" TextColor="Gray" />
                    <Label Text="•" FontSize="14" TextColor="Gray" />
                    <Label Text="[Location placeholder]" FontSize="14" TextColor="Gray" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

           
            <VerticalStackLayout x:Name="DescriptionRegion" Spacing="10" Margin="0, 10, 0, 0">
                <Label Text="About this event" FontSize="18" FontAttributes="Bold" />
                <Label Text="{Binding Description}" FontSize="16" LineHeight="1.4" TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
            </VerticalStackLayout>

            
            <VerticalStackLayout x:Name="ActionRegion" Margin="0, 20, 0, 0">
             
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
