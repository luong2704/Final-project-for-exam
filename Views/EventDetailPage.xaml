<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Campus.ViewModels"
             xmlns:conv="clr-namespace:Campus.Converters"
             x:Class="Campus.Views.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             Title="Event Details"
             BackgroundColor="#F7FAFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Border StrokeThickness="0"
                    HeightRequest="220"
                    StrokeShape="RoundRectangle 0,0,20,20"
                    BackgroundColor="#E2E8F0">
                <Image Source="{Binding Image}" Aspect="AspectFill" />
            </Border>

            <VerticalStackLayout Padding="16" Spacing="16">
                <VerticalStackLayout x:Name="TitleRegion" Spacing="6">
                    <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding StatusColor}"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4">
                            <Label Text="{Binding EventStatus}"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </Border>

                        <Border StrokeThickness="0"
                                BackgroundColor="#E5E7EB"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4">
                            <Label Text="{Binding Category}"
                                   TextColor="#374151"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="14" TextColor="#718096" />
                        <Label Text="-" FontSize="14" TextColor="#718096" />
                        <Label Text="{Binding Location}" FontSize="14" TextColor="#718096" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="White"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="About this event"
                               FontSize="16"
                               TextColor="#2D3748"
                               FontAttributes="Bold" />

                        <Label Text="{Binding Description}"
                               FontSize="15"
                               TextColor="#4A5568"
                               LineBreakMode="WordWrap" />

                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="#F0FFF4"
                                Padding="14,10"
                                IsVisible="{Binding IsRegistered}">
                            <Label Text="You are registered for this event"
                                   FontSize="14"
                                   TextColor="#276749"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout x:Name="ActionRegion" Spacing="12">
                    <Button Text="Register for this Event"
                            Command="{Binding RegisterCommand}"
                            IsVisible="{Binding IsRegistered, Converter={StaticResource InvertBoolConverter}}"
                            BackgroundColor="#00697F"
                            TextColor="White"
                            HeightRequest="52"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            FontSize="16" />

                    <Button Text="Back to Events"
                            BackgroundColor="#EDF2F7"
                            TextColor="#4A5568"
                            HeightRequest="50"
                            CornerRadius="12"
                            FontSize="14"
                            Command="{Binding GoBackCommand}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
