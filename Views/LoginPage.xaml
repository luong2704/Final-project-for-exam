<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.LoginPage"
             BackgroundColor="White"
             Title="Login">

    <VerticalStackLayout
        Padding="30"
        Spacing="25"
        VerticalOptions="Center">

        <!-- Title -->
        <Label
            Text="Campus Activity Manager"
            FontSize="34"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="#00697F"/>

        <!-- Login Card -->
        <Border
            StrokeThickness="0"
            StrokeShape="RoundRectangle 15"
            BackgroundColor="#F4F8F9"
            Padding="20">

            <VerticalStackLayout Spacing="15">

            </VerticalStackLayout>

        </Border>

    </VerticalStackLayout>

</ContentPage>