<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.LoginPage"
             BackgroundColor="White"
             Title="Login">

    <VerticalStackLayout
        Padding="30"
        Spacing="25"
        VerticalOptions="Center">

        <!-- Title -->
        <Label
            Text="Campus Activity Manager"
            FontSize="34"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="#00697F"/>

        <!-- Login Card -->
        <Border
            StrokeThickness="0"
            StrokeShape="RoundRectangle 15"
            BackgroundColor="#F4F8F9"
            Padding="20">

            <VerticalStackLayout Spacing="15">

                <Entry
                    Placeholder="Email"
                    Keyboard="Email"
                    HeightRequest="45"
                    BackgroundColor="White"
                    Margin="0,5"/>

                <Entry
                    Placeholder="Password"
                    IsPassword="True"
                    HeightRequest="45"
                    BackgroundColor="White"
                    Margin="0,5"/>
                
                <Button
                    Text="Login"
                    HeightRequest="50"
                    BackgroundColor="#00697F"
                    TextColor="White"
                    CornerRadius="10"
                    FontAttributes="Bold"/>

                <Label
                    Text="Invalid login"
                    TextColor="Red"
                    IsVisible="False"
                    HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Border>

    </VerticalStackLayout>

</ContentPage>