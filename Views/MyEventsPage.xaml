<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Campus.Views"
             x:Class="Campus.Views.MyEventsPage">

    <CollectionView ItemsSource="{Binding MyEventsList}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <views:EventCardView />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>