<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="Dashboard" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#333333" />

            <!-- Statistics Cards Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Total Events Card -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Total Events" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="{Binding TotalEvents}" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#2196F3" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Upcoming Events Card -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Upcoming Events" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="{Binding UpcomingEvents}" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#FF9800" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Attended Events Card -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Attended" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="{Binding AttendedEvents}" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#4CAF50" />
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Saved Events Card -->
                <Frame Grid.Row="1" Grid.Column="1" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Saved" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="{Binding SavedEvents}" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#9C27B0" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
            <!-- Recent Events Section -->
            <Label Text="Recent Events" 
                   FontSize="18" 
                   FontAttributes="Bold"
                   TextColor="#333333"
                   Margin="0,10,0,0" />

			<!-- Recent Events List -->
			<Frame CornerRadius="8" BorderColor="#E0E0E0" Padding="15" HasShadow="True">
				<VerticalStackLayout Spacing="10">
					<CollectionView ItemsSource="{Binding RecentEvents}"
								   SelectionMode="Single"
								   SelectionChangedCommand="{Binding ViewEventDetailsCommand}"
								   SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Frame CornerRadius="6" BorderColor="#F0F0F0" Padding="10" Background="#F9F9F9">
									<VerticalStackLayout Spacing="4">
										<Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" />
										<Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="#999999" />
									</VerticalStackLayout>
								</Frame>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>

                    <!-- Empty State -->
                    <Label Text="No upcoming events"
                           FontSize="14"
                           TextColor="#999999"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding RecentEvents.Count, Converter={StaticResource InvertedBoolConverter}}" />
				</VerticalStackLayout>
			</Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>