<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="Dashboard" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#333333" />

            <!-- Statistics Cards Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Total Events Card -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Tổng Sự Kiện" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="24" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#2196F3" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Upcoming Events Card -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Sự Kiện Sắp Tới" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="8" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#FF9800" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Attended Events Card -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Đã Tham Gia" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="12" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#4CAF50" />
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Saved Events Card -->
                <Frame Grid.Row="1" Grid.Column="1" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Đã Lưu" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="5" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#9C27B0" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
            <!-- Recent Events Section -->
            <Label Text="Sự Kiện Gần Đây" 
                   FontSize="18" 
                   FontAttributes="Bold"
                   TextColor="#333333"
                   Margin="0,10,0,0" />

            <!-- Placeholder for Recent Events List -->
            <Frame CornerRadius="8" BorderColor="#E0E0E0" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Frame CornerRadius="6" BorderColor="#F0F0F0" Padding="10" Background="#F9F9F9">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Workshop C#" FontAttributes="Bold" FontSize="14" />
                            <Label Text="15/04/2026" FontSize="12" TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame CornerRadius="6" BorderColor="#F0F0F0" Padding="10" Background="#F9F9F9">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tech Talk" FontAttributes="Bold" FontSize="14" />
                            <Label Text="18/04/2026" FontSize="12" TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame CornerRadius="6" BorderColor="#F0F0F0" Padding="10" Background="#F9F9F9">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Hackathon" FontAttributes="Bold" FontSize="14" />
                            <Label Text="20/04/2026" FontSize="12" TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>