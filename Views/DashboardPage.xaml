<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Campus.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="Dashboard" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#333333" />

            <!-- Statistics Cards Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Total Events Card -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Tổng Sự Kiện" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="24" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#2196F3" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Upcoming Events Card -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Sự Kiện Sắp Tới" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="8" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#FF9800" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Attended Events Card -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       CornerRadius="12" 
                       BorderColor="#E0E0E0" 
                       Padding="15"
                       HasShadow="True"
                       Background="White">
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Đã Tham Gia" 
                               FontSize="14" 
                               TextColor="#999999" />
                        <Label Text="12" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#4CAF50" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>